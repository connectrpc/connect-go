# A req.Msg access captured inside a closure unwraps after the param flips.
stubs v2
exec migrate
cmp stdout out.txt
exec migrate -w
exec go build ./...
exec migrate
! stdout 'Proposed rewrites'
-- service.go --
package app

import (
	"context"

	"connectrpc.com/connect"
	pingv1 "example.com/app/gen/connect/ping/v1"
	"example.com/app/gen/connect/ping/v1/pingv1connect"
)

type pingServer struct {
	pingv1connect.UnimplementedPingServiceHandler
}

func runInTx(ctx context.Context, fn func(ctx context.Context) error) error {
	return fn(ctx)
}

func (s *pingServer) Ping(ctx context.Context, req *connect.Request[pingv1.PingRequest]) (*connect.Response[pingv1.PingResponse], error) {
	var text string
	if err := runInTx(ctx, func(ctx context.Context) error {
		// req captured from outer scope.
		text = req.Msg.Text
		return nil
	}); err != nil {
		return nil, err
	}
	resp := &pingv1.PingResponse{Text: text}
	return connect.NewResponse(resp), nil
}
