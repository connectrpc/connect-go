# The v1 connect.CallInfoForHandlerContext renames to connect.CallInfoForServerContext.
stubs v2
exec migrate
cmp stdout out.txt
exec migrate -w
exec go build ./...
exec migrate
! stdout 'Proposed rewrites'
-- service.go --
package app

import (
	"context"

	"connectrpc.com/connect"
	pingv1 "example.com/app/gen/connect/ping/v1"
	"example.com/app/gen/connect/ping/v1/pingv1connect"
)

type pingServer struct {
	pingv1connect.UnimplementedPingServiceHandler
}

func (s *pingServer) Ping(ctx context.Context, req *connect.Request[pingv1.PingRequest]) (*connect.Response[pingv1.PingResponse], error) {
	info, _ := connect.CallInfoForHandlerContext(ctx)
	token := info.RequestHeader().Get("Authorization")
	return connect.NewResponse(&pingv1.PingResponse{Text: token}), nil
}
