+func (s *pingServer) Ping(ctx context.Context, req *pingv1.PingRequest) (*pingv1.PingResponse, error) {
+	info, _ := connect.CallInfoForServerContext(ctx)
 	token := info.RequestHeader().Get("Authorization")
-	return connect.NewResponse(&pingv1.PingResponse{Text: token}), nil
+	return &pingv1.PingResponse{Text: token}, nil
 }
 


