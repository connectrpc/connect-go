// Package connect is a minimal stand-in for connectrpc.com/connect/v2.
package connect

type Client struct{}

type (
	Transport         interface{ transport() }
	ClientInterceptor interface{ clientInterceptor() }
)

func NewClient(Transport, ...ClientInterceptor) *Client { return &Client{} }
