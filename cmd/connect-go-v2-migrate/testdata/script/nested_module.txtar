// Code generated by protoc-gen-connect-go. DO NOT EDIT.

package pingv1connect

import "connectrpc.com/connect/v2"

type PingServiceClient struct{ client *connect.Client }

// Deliberately the v1-shaped constructor so the fixture's hand-written call
// site is the v1 form the tool must reshape.
func NewPingServiceClient(httpClient any, baseURL string) PingServiceClient {
	return PingServiceClient{}
}
-- child/go.mod --
module example.com/app

go 1.25

require connectrpc.com/connect/v2 v2.0.0

replace connectrpc.com/connect/v2 => ./connectv2
