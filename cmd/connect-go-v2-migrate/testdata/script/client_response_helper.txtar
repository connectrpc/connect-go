# A local helper parameter *connect.Request[T] unwraps to *T.
stubs v2
exec migrate
cmp stdout out.txt
exec migrate -w
exec go build ./...
exec migrate
! stdout 'Proposed rewrites'
-- service.go --
package app

import (
	"context"

	"connectrpc.com/connect"
	pingv1 "example.com/app/gen/connect/ping/v1"
)

type wrapper struct {
	Msg string
}

func buildWrapper(req *connect.Request[pingv1.PingRequest]) *wrapper {
	return &wrapper{}
}

func use(ctx context.Context) string {
	req := connect.NewRequest(&pingv1.PingRequest{})
	w := buildWrapper(req)
	return w.Msg
}
