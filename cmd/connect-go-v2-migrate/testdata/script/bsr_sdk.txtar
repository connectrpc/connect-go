package app

import (
	testv1connect "buf.build/gen/go/example/test/connectrpc/go"
	"connectrpc.com/connect"
	"connectrpc.com/otelconnect"
)

var _ = otelconnect.Name

// ping calls the BSR-generated client with the v1 request wrapper.
func ping() (*testv1connect.PingResponse, error) {
	client := testv1connect.NewServiceClient("http://localhost:8080")
	res, err := client.Ping(connect.NewRequest(&testv1connect.PingRequest{Name: "x"}))
	if err != nil {
		return nil, err
	}
	return res.Msg, nil
}
