# Regression: stream.Err() referenced outside a return (a log call) must be
stubs v2
exec migrate
cmp stdout out.txt
exec migrate -w
exec go build ./...
exec migrate
! stdout 'Proposed rewrites'
-- service.go --
package app

import (
	"context"
	"log"

	"connectrpc.com/connect"
	pingv1 "example.com/app/gen/connect/ping/v1"
	"example.com/app/gen/connect/ping/v1/pingv1connect"
)

type pingServer struct {
	pingv1connect.UnimplementedPingServiceHandler
}

func (s *pingServer) Sum(ctx context.Context, stream *connect.ClientStream[pingv1.SumRequest]) (*connect.Response[pingv1.SumResponse], error) {
	var sum int64
	for stream.Receive() {
		sum += stream.Msg().Number
	}
	if stream.Err() != nil {
		log.Println("sum failed:", stream.Err())
		return nil, stream.Err()
	}
	return connect.NewResponse(&pingv1.SumResponse{Sum: sum}), nil
}
