-		connect.WithSendMaxBytes(1),
-		connect.WithCompressMinBytes(1),
-		connect.WithHTTPGet(),
-		connect.WithHTTPGetMaxURLSize(1, true),
-		connect.WithRequireConnectProtocolHeader(),
+		connecthttp.WithSendGzip(),
