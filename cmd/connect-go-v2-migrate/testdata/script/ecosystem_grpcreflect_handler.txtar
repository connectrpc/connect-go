# grpcreflect handler import flips to /v2 (golden-only: grpcreflect v2 unavailable).
exec migrate
cmp stdout out.txt
-- ecosystem_grpcreflect_handler.go --
package example

import (
	"net/http"

	"connectrpc.com/grpcreflect"
)

func registerReflection(mux *http.ServeMux) {
	reflector := grpcreflect.NewStaticReflector("acme.user.v1.UserService")
	mux.Handle(grpcreflect.NewHandlerV1(reflector))
	mux.Handle(grpcreflect.NewHandlerV1Alpha(reflector))
}
