# Negative test: a non-service stream param and its Send must be left untouched.
exec migrate
cmp stdout out.txt
exec go build ./...
! stdout 'Proposed rewrites'
-- service.go --
package p

import (
	"context"

	"connectrpc.com/connect"
)

type out struct{}

func h(ctx context.Context, s *connect.ServerStream[out]) error {
	return s.Send(&out{})
}
