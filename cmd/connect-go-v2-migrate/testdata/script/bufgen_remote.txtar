# buf.gen.yaml remote plugin: bumped to connectrpc/go v2 and simple opt dropped.
exec migrate
cmp stdout out.txt
exec migrate -w
cmp buf.gen.yaml want.yaml
exec go build ./...
-- doc.go --
package app
-- buf.gen.yaml --
version: v2
plugins:
  - remote: buf.build/connectrpc/go:v1.18.1
    out: gen
    opt: simple=true
-- want.yaml --
version: v2
plugins:
  - remote: buf.build/connectrpc/go:v2.0.0
    out: gen
-- out.txt --
Proposed rewrites (rerun with -w to apply):
  ./buf.gen.yaml: bufgen_pin_remote_v2=1 bufgen_remove_simple=1
