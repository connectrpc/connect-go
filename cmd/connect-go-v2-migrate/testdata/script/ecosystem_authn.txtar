exec migrate
cmp stdout out.txt
-- ecosystem_authn.go --
package example

import (
	"context"
	"net/http"

	"connectrpc.com/authn"
)

func authenticate(_ context.Context, req *http.Request) (any, error) {
	token, ok := authn.BearerToken(req)
	if !ok {
		return nil, authn.Errorf("missing bearer token")
	}
	return token, nil
}

func wrap(mux *http.ServeMux) http.Handler {
	middleware := authn.NewMiddleware(authenticate)
	return middleware.Wrap(mux)
}
