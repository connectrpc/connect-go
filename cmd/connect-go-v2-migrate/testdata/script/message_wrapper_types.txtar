# Wrapper types in struct fields and function-type signatures flip to bare messages.
stubs v2
exec migrate
cmp stdout out.txt
exec migrate -w
exec go build ./...
exec migrate
! stdout 'Proposed rewrites'
-- service.go --
package app

import (
	"testing"

	"connectrpc.com/connect"
	pingv1 "example.com/app/gen/connect/ping/v1"
)

type testCase struct {
	assertions func(*testing.T, *connect.Response[pingv1.PingResponse], error)
	build      func() *connect.Request[pingv1.PingRequest]
}

func run(t *testing.T, check func(*testing.T, *connect.Response[pingv1.PingResponse], error)) {
	var collected []*connect.Response[pingv1.PingResponse]
	check(t, &connect.Response[pingv1.PingResponse]{}, nil)
	_ = collected
}

func approve(_ *connect.Request[pingv1.PingRequest]) (*connect.Response[pingv1.PingResponse], error) {
	return &connect.Response[pingv1.PingResponse]{}, nil
}
-- out.txt --
