# A dangling req.Msg in a channel send is dropped to req after the param unwraps.
stubs v2
exec migrate
cmp stdout out.txt
exec migrate -w
exec go build ./...
exec migrate
! stdout 'Proposed rewrites'
-- service.go --
package app

import (
	"context"

	"connectrpc.com/connect"
	pingv1 "example.com/app/gen/connect/ping/v1"
	"example.com/app/gen/connect/ping/v1/pingv1connect"
)

type pingServer struct {
	pingv1connect.UnimplementedPingServiceHandler
}

func (s *pingServer) Ping(ctx context.Context, req *connect.Request[pingv1.PingRequest]) (*connect.Response[pingv1.PingResponse], error) {
	out := make(chan *pingv1.PingRequest, 1)
	out <- req.Msg
	return connect.NewResponse(&pingv1.PingResponse{}), nil
}
-- out.txt --
Proposed rewrites (rerun with -w to apply):
