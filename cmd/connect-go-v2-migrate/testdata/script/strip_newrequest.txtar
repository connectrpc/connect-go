-- service.go --
package app

import (
	"context"

	"connectrpc.com/connect"
	pingv1 "example.com/app/gen/connect/ping/v1"
	"example.com/app/gen/connect/ping/v1/pingv1connect"
)

func call(ctx context.Context, c pingv1connect.PingServiceClient) error {
	resp, err := c.Ping(ctx, connect.NewRequest(&pingv1.PingRequest{Text: "hi"}))
	if err != nil {
		return err
	}
	_ = resp.Msg.Text
	return nil
}
