-- client_construction.go --
package example

import (
	"net/http"

	"example.com/app/gen/connect/ping/v1/pingv1connect"
)

func newClient() pingv1connect.PingServiceClient {
	return pingv1connect.NewPingServiceClient(
		http.DefaultClient,
		"http://localhost:8080/",
	)
}
