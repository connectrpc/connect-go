 	"context"
 
-	"connectrpc.com/connect"
+	"connectrpc.com/connect/v2"
 	pingv1 "example.com/app/gen/connect/ping/v1"
 	"example.com/app/gen/connect/ping/v1/pingv1connect"
 )
@@ -11,8 +11,9 @@
 func call(ctx context.Context, client pingv1connect.PingServiceClient) error {
 	info := "trace"
 	callInfo := "span"
-	req := connect.NewRequest(&pingv1.PingRequest{Text: "hello"})
-	req.Header().Set("X-Trace", info+callInfo)
+	req := &pingv1.PingRequest{Text: "hello"}
+	ctx, callInfo2 := connect.NewClientContext(ctx)
+	callInfo2.RequestHeader().Set("X-Trace", info+callInfo)
 	_, err := client.Ping(ctx, req)
 	return err
 }


