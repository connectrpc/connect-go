# A whole option slice of transport options moves to []connecthttp.Option.
stubs v2
exec migrate
cmp stdout out.txt
exec migrate -w
exec go build ./...
exec migrate
! stdout 'Proposed rewrites'
-- service.go --
package p

import (
	"connectrpc.com/connect"
)

func options() []connect.HandlerOption {
	return []connect.HandlerOption{
		connect.WithReadMaxBytes(1024),
		connect.WithSendMaxBytes(2048),
		connect.WithCompressMinBytes(512),
		connect.WithRequireConnectProtocolHeader(),
		connect.WithGRPC(),
		connect.WithCodec(nil),
	}
}
-- out.txt --
Proposed rewrites (rerun with -w to apply):
