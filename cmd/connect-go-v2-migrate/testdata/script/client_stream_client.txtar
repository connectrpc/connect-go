# Client-streaming consumer (Sum): single-return becomes (stream, err) and res.Msg -> res.
stubs v2
exec migrate
cmp stdout out.txt
exec migrate -w
exec go build ./...
exec migrate
! stdout 'Proposed rewrites'
-- service.go --
package app

import (
	"context"

	"connectrpc.com/connect"
	pingv1 "example.com/app/gen/connect/ping/v1"
	"example.com/app/gen/connect/ping/v1/pingv1connect"
)

type pingServer struct {
	pingv1connect.UnimplementedPingServiceHandler
}

func (s *pingServer) Sum(ctx context.Context, stream *connect.ClientStream[pingv1.SumRequest]) (*connect.Response[pingv1.SumResponse], error) {
	return connect.NewResponse(&pingv1.SumResponse{}), nil
}

func runSum(ctx context.Context, client pingv1connect.PingServiceClient) (*pingv1.SumResponse, error) {
	stream := client.Sum(ctx)
	for i := int64(1); i <= 3; i++ {
		if err := stream.Send(&pingv1.SumRequest{Number: i}); err != nil {
			return nil, err
		}
	}
	res, err := stream.CloseAndReceive()
	if err != nil {
		return nil, err
	}
	return res.Msg, nil
}
