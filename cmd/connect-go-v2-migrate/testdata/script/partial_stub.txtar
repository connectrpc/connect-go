package app

import (
	"context"
	"net/http"

	"connectrpc.com/connect"

	"example.com/app/gen/bv1"
	"example.com/app/gen/bv1/bv1connect"
)

// ping binds to service B, whose stub is still v1, so it is deferred.
func ping(ctx context.Context) error {
	client := bv1connect.NewBServiceClient(http.DefaultClient, "http://localhost")
	_, err := client.Ping(ctx, connect.NewRequest(&bv1.PingRequest{N: 1}))
	return err
}
