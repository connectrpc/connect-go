package connect

import "net/http"

type HTTPClient interface{ Do(*http.Request) (*http.Response, error) }
type ClientOption interface{ clientOption() }
type Client struct{}

func NewClient(HTTPClient, string, ...ClientOption) *Client { return &Client{} }
