# Partial migration: consumer_a's stubs are v2 (it migrates now), consumer_b's
# are still v1 (deferred until regenerated). A dry-run phase-decision check:
# not a regenerate-first run, and consumer_b is left for later.
exec migrate
cmp stdout out.txt
stdout 'Deferred until their connect stubs are regenerated'
stdout 'strip_new_request'
! stdout 'First, move the dependencies'
